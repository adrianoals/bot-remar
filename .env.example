# Configurações da API (FastAPI)
PROJECT_NAME="Remar Chatbot"
API_VERSION="v1"

# MegaAPI (WhatsApp)
MEGA_API_URL="https://apinocode01.megaapi.com.br"
MEGA_API_INSTANCE_KEY="sua_instancia_aqui"
